{
  "manifest_version": 3,
  "name": "DecideSpin (随机转盘)",
  "description": "Have trouble making choices? Just click once! 有选择困难症？只需要点击一下！",
  "version": "1.0.1",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DecideSpin (随机转盘)"
  },
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": ["setting.html"],
      "matches": ["<all_urls>"]
    }
  ]
}